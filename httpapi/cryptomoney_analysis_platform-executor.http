### Создание лонг лимитного ордера
POST http://localhost:8082/api/trading/futures/limit/long
Content-Type: application/json

{
  "instrument": "BTC-USDT",
  "limitPrice": 66540,
  "positionSizeUsdt": 40,
  "stopLossPercent": 0.3,
  "takeProfitPercent": 3
}

### Создание лонг следующего ордера
POST http://localhost:8082/api/trading/futures/chase/long
Content-Type: application/json

{
  "instrument": "BTC-USDT",
  "positionSizeUsdt": 20,
  "stopLossPercent": 0.6,
  "reduceOnly": false
}

